    float radius_;
    int damage_;
    bool alive_;
};
```

**Enemy** `include/Enemy.hpp`：

```cpp
class Enemy {
public:
    void update(float dt);           // 移动
    void takeDamage(int damage);     // 受伤
    bool isDead() const;             // 是否死亡
    int contactDamage() const;       // 撞击伤害

private:
    Vector2 position_, velocity_;
    float radius_;
    int hp_;
